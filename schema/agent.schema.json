{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Markdown Frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "oneOf": [
        {"pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"},
        {"enum": ["Explore"]}
      ]
    },
    "description": {
      "type": "string",
      "pattern": "Use when"
    },
    "model": {
      "type": "string"
    },
    "tools": {
      "type": "string"
    },
    "disallowedTools": {
      "type": "string"
    },
    "x-registry-permission": {
      "type": "string",
      "enum": ["read-only", "edit"]
    },
    "x-allow-tools-allowlist": {
      "type": "string",
      "enum": ["true"]
    },
    "x-mechanical": {
      "type": "string",
      "enum": ["true"],
      "description": "Marks a mechanical leaf agent (pure retrieval/pass-through, no synthesis). Exempts it from the universal tool-priority inline: the rubric is unreachable under a hard MCP allowlist or contradicts a leaf worker's brief."
    },
    "color": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
