{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Markdown Frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "description": {
      "type": "string",
      "pattern": "Use when"
    },
    "model": {
      "type": "string"
    },
    "tools": {
      "type": "string"
    },
    "disallowedTools": {
      "type": "string"
    },
    "x-registry-permission": {
      "type": "string",
      "enum": ["read-only", "edit"]
    },
    "x-allow-tools-allowlist": {
      "type": "string",
      "enum": ["true"]
    },
    "color": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
