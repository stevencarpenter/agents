# Copy to eval/.env (gitignored) or export these before running.

# Required: the agents under test AND the judges call Anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# MLflow tracking. A SQL-backed server (or `mlflow server`) is needed for judge
# REGISTRATION; with a bare local file store the run falls back to inline scorers.
#   mlflow server --backend-store-uri sqlite:///mlflow.db --host 127.0.0.1 --port 5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# Optional: pin an existing experiment id (otherwise --experiment name is used).
# MLFLOW_EXPERIMENT_ID=

# Models (verify these ids are callable by your key). The agents deploy with
# model: inherit (Opus in Claude Code); Sonnet is the cheaper eval default.
EVAL_AGENT_MODEL=claude-sonnet-4-6
EVAL_JUDGE_MODEL=anthropic:/claude-opus-4-8

# Provider for the AGENT calls. Default "anthropic" needs a console key above.
# With cloud-provider credentials, switch providers (no Anthropic key needed):
#   uv sync --project eval --extra bedrock
#   EVAL_PROVIDER=bedrock \
#   EVAL_AGENT_MODEL=anthropic.claude-opus-4-<...>-v1:0 \   # Bedrock model id / inference-profile (verify in your region)
#   EVAL_JUDGE_MODEL=bedrock:/anthropic.claude-opus-4-<...>-v1:0
# Vertex equivalent:
#   uv sync --project eval --extra vertex
#   EVAL_PROVIDER=vertex  CLOUD_ML_REGION=us-east5  ANTHROPIC_VERTEX_PROJECT_ID=<gcp-project>
#   EVAL_AGENT_MODEL=claude-opus-4@<...>  EVAL_JUDGE_MODEL=vertex_ai:/claude-opus-4@<...>
EVAL_PROVIDER=anthropic
